12. SCROLLBAR
Custom Scrollbar CSS
css::-webkit-scrollbar {
  width: 4px;
  height: 4px;
}
::-webkit-scrollbar-track {
  background: transparent;
}
::-webkit-scrollbar-thumb {
  background: #6EE7B7; /* Light emerald */
  border-radius: 10px;
}
::-webkit-scrollbar-thumb:hover {
  background: #10B981; /* Main green */
}

/* Dark Mode */
.dark ::-webkit-scrollbar-thumb {
  background: #6B7280;
}
.dark ::-webkit-scrollbar-thumb:hover {
  background: #9CA3AF;
}

/* Custom class for chat areas */
.custom-scrollbar::-webkit-scrollbar-thumb {
  background: #A7F3D0;
}

13. ANIMATIONS
Fade In
css@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in {
  animation: fadeIn 0.4s ease-out forwards;
}
Pop In (Login Card)
css@keyframes popIn {
  0% { opacity: 0; transform: scale(0.9); }
  50% { transform: scale(1.02); }
  100% { opacity: 1; transform: scale(1); }
}
.animate-pop-in {
  animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}
Bounce In (Notification Badge)
css@keyframes bounce-in {
  0% { transform: scale(0); }
  70% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
Spin (Loading)
css@keyframes spin {
  to { transform: rotate(360deg); }
}
Sidebar Toggle
css.sidebar-collapsed #sidebar {
  width: 80px;
}
.sidebar-collapsed .sidebar-text {
  display: none;
}

14. DARK MODE
CSS Variables Override
css.dark {
  --bg-app: #022C22;
  --surface: #064E3B;
  --bg-card: #064E3B;
  --text-primary: #ECFDF5;
  --text-secondary: #6EE7B7;
  --text-muted: #047857;
  --border-color: #065F46;
}
Implementation
javascriptfunction toggleDarkMode() {
  isDarkMode = !isDarkMode;
  if (isDarkMode) {
    document.documentElement.classList.add('dark');
    localStorage.setItem('theme', 'dark');
  } else {
    document.documentElement.classList.remove('dark');
    localStorage.setItem('theme', 'light');
  }
  renderCurrentPage();
}
Early Theme Detection (in Head)
html<script>
  (function() {
    const theme = localStorage.getItem('theme') || 'light';
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    }
  })();
</script>

